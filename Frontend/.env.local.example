# Copy this file to `.env.local` and fill in values, then restart Vite dev server
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Gemini API key (set to enable AI features)
VITE_GEMINI_KEY=your_gemini_api_key_here

# Optional app identifier used by the app for document paths
VITE_APP_ID=your_app_id_for_artifacts

# Optional: Use backend proxy for Gemini (set to "true" to enable). When enabled, the frontend will POST to /gen on the backend.
VITE_GEMINI_USE_PROXY=false
# Optional: You can set the backend base URL if your backend is hosted elsewhere (defaults to same origin)
VITE_BACKEND_URL=http://localhost:8080